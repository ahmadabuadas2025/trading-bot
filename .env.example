# SolanaMemBot secrets. Copy to .env and fill in what you have.
# All keys are OPTIONAL in paper mode. Live mode REQUIRES WALLET_PRIVATE_KEY.

# Required for live trading only.
WALLET_PRIVATE_KEY=

# Optional LLM analysis (free at https://openrouter.ai). If missing,
# the bot skips LLM scans and uses math-only scoring.
OPENROUTER_API_KEY=

# Optional social data enrichment (free tier).
LUNARCRUSH_API_KEY=

# Optional real-time wallet monitoring and OHLCV for ATR.
HELIUS_API_KEY=
BIRDEYE_API_KEY=

# Optional Solana RPC override (defaults to Helius if key set, else
# public RPC).
SOLANA_RPC_URL=
